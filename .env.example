# Danny AI Configuration
# Copy this file to .env and fill in your values

# Claude API (Direct - for local testing)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AWS Configuration (for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
USE_BEDROCK=false

# Calendly Integration
CALENDLY_API_KEY=your_calendly_api_key_here
CALENDLY_USER_URI=https://api.calendly.com/users/YOUR_USER_UUID

# Practice Configuration
PRACTICE_NAME=Sample Dental Practice
PRACTICE_PHONE=+1-555-123-4567
DEFAULT_LANGUAGE=en

# Compliance
REQUIRE_RECORDING_CONSENT=true
LOG_LEVEL=INFO

# Email Confirmation (SMTP)
# For Gmail: use smtp.gmail.com + an App Password (not your regular password)
# Create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=Your Practice Name
